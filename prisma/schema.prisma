generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  GUEST
  TRIAL_MEMBER
  ACCEPTED_MEMBER
  ACTIVE_WORKER
  MODERATOR
  COORDINATOR
  ADMIN
  FOUNDER
}

enum Rank {
  F
  E
  D
  C
  B
  A
  S
  SS
  SSS
}

enum QuestStatus {
  OPEN
  FULL
  CLOSED
}

enum ClaimStatus {
  CLAIMED
  IN_PROGRESS
  SUBMITTED
  APPROVED
  REJECTED
}

enum SuggestionStatus {
  PENDING
  DISCUSSING
  APPROVED
  DECLINED
}

enum TrialStatus {
  PENDING
  UNDER_REVIEW
  ACCEPTED
  REJECTED
}

enum MemberStatus {
  ACTIVE
  SUSPENDED
  BANNED
  INACTIVE
}

enum AchievementType {
  PERMANENT
  COMPETITIVE
  TEMPORARY
}

enum PostVisibility {
  PUBLIC
  MEMBERS_ONLY
  ACCEPTED_ONLY
}

enum PayoutStatus {
  NOT_APPLICABLE
  PENDING
  PAID
}

model User {
  id                 String       @id @default(cuid())
  email              String       @unique
  name               String?
  nickname           String?      @unique
  passwordHash       String?
  image              String?
  profilePicUrl      String?
  role               Role         @default(GUEST)
  rank               Rank         @default(F)
  xp                 Int          @default(0)
  status             MemberStatus @default(ACTIVE)
  skills             String[]
  bio                String?
  portfolioUrl       String?
  socialLinks        Json?

  // Extended profile
  timezone           String?
  country            String?
  workStyle          String?
  preferredTaskType  String?
  experience         String?
  availabilityText   String?
  portfolioVault     Json?

  // Trust system
  trustScore         Int          @default(50)
  trustLevel         String       @default("NEW")

  // Identity / verification flags
  emailVerified      DateTime?
  socialVerified     Boolean      @default(false)
  locationVerified   Boolean      @default(false)
  faceVerified       Boolean      @default(false)
  identityVerified   Boolean      @default(false)

  // Active title
  activeTitle        String?

  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  accounts           Account[]
  sessions           Session[]
  trial              Trial?
  questClaims        QuestClaim[] @relation("QuestClaimUser")
  questSuggestions   QuestSuggestion[]
  messagesFrom       Message[]    @relation("MessageFrom")
  messagesTo         Message[]    @relation("MessageTo")
  chatMessages       ChatMessage[]
  xpLogs             XpLog[]
  adminNotes         AdminNote[]  @relation("NotesAbout")
  notesWritten       AdminNote[]  @relation("NotesByAdmin")
  reportsFrom        Report[]     @relation("ReportsBy")
  reportsAbout       Report[]     @relation("ReportsAbout")
  warnings           Warning[]
  activityLogs       ActivityLog[]
  arenaEntries       ArenaEntry[]
  adminPermission    AdminPermission?
  achievements       UserAchievement[]
  titles             UserTitle[]
  notifications      Notification[]
  trustEvents        TrustEvent[]
  postsAuthored      CommunityPost[]
  verifications      ProfileVerification[]
  feedbacks          Feedback[]
  feedbackReplies    FeedbackReply[]
  featureUnlocks     UserFeatureUnlock[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model Trial {
  id               String      @id @default(cuid())
  userId           String      @unique
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  age              Int
  skills           String[]
  strengths        String
  whyJoin          String
  availability     String
  contactInfo      String
  portfolioUrl     String?
  status           TrialStatus @default(PENDING)
  score            Int?
  aiScore          Int?
  aiSummary        String?
  aiRecommendation String?
  judgeNotes       String?
  assignedTaskId   String?
  assignedTask     TrialTask?  @relation(fields: [assignedTaskId], references: [id])
  submittedAt      DateTime    @default(now())
  reviewedAt       DateTime?
}

model Quest {
  id              String      @id @default(cuid())
  title           String
  category        String
  difficulty      String
  rankRequired    Rank        @default(F)
  deadline        DateTime?
  rewardXp        Int         @default(50)
  cashReward      Float?
  instructions    String
  status          QuestStatus @default(OPEN)
  maxParticipants Int         @default(1)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  claims          QuestClaim[]
}

model QuestClaim {
  id             String       @id @default(cuid())
  questId        String
  quest          Quest        @relation(fields: [questId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation("QuestClaimUser", fields: [userId], references: [id], onDelete: Cascade)
  status         ClaimStatus  @default(CLAIMED)
  claimedAt      DateTime     @default(now())
  submittedAt    DateTime?
  submissionUrl  String?
  submissionNote String?
  reviewedAt     DateTime?
  reviewNote     String?
  payoutStatus   PayoutStatus @default(NOT_APPLICABLE)
  paidAt         DateTime?
  clientRating   Int?
  clientFeedback String?

  @@unique([questId, userId])
  @@index([userId])
  @@index([questId])
}

model QuestSuggestion {
  id              String           @id @default(cuid())
  suggestedById   String
  suggestedBy     User             @relation(fields: [suggestedById], references: [id], onDelete: Cascade)
  title           String
  category        String
  difficulty      String
  rankRequired    Rank             @default(F)
  rewardXp        Int              @default(50)
  cashReward      Float?
  instructions    String
  deadline        DateTime?
  maxParticipants Int              @default(1)
  status          SuggestionStatus @default(PENDING)
  founderNote     String?
  resultingQuestId String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String?
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
}

model Message {
  id        String   @id @default(cuid())
  fromId    String
  toId      String
  content   String
  read      Boolean  @default(false)
  flagged   Boolean  @default(false)
  flagReason String?
  createdAt DateTime @default(now())
  from      User     @relation("MessageFrom", fields: [fromId], references: [id])
  to        User     @relation("MessageTo", fields: [toId], references: [id])
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  channel   String   @default("general")
  content   String
  flagged   Boolean  @default(false)
  flagReason String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model XpLog {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  reason    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model AdminNote {
  id        String   @id @default(cuid())
  aboutId   String
  byId      String
  note      String
  createdAt DateTime @default(now())
  about     User     @relation("NotesAbout", fields: [aboutId], references: [id])
  by        User     @relation("NotesByAdmin", fields: [byId], references: [id])
}

model Report {
  id              String   @id @default(cuid())
  reportedById    String
  reportedAboutId String
  reason          String
  details         String?
  resolved        Boolean  @default(false)
  createdAt       DateTime @default(now())
  reportedBy      User     @relation("ReportsBy", fields: [reportedById], references: [id])
  reportedAbout   User     @relation("ReportsAbout", fields: [reportedAboutId], references: [id])
}

model Warning {
  id        String   @id @default(cuid())
  userId    String
  reason    String
  issuedBy  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  details   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model ArenaChallenge {
  id          String       @id @default(cuid())
  title       String
  description String
  type        String
  xpReward    Int          @default(50)
  cashReward  Float?
  endsAt      DateTime
  createdAt   DateTime     @default(now())
  entries     ArenaEntry[]
}

model ArenaEntry {
  id          String         @id @default(cuid())
  userId      String
  challengeId String
  response    String?
  score       Int?
  createdAt   DateTime       @default(now())
  user        User           @relation(fields: [userId], references: [id])
  challenge   ArenaChallenge @relation(fields: [challengeId], references: [id])
}

model TrialTask {
  id            String   @id @default(cuid())
  title         String
  description   String
  category      String
  difficulty    String
  instructions  String
  deadlineHours Int      @default(24)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  assignments   Trial[]
}

model AdminPermission {
  id          String   @id @default(cuid())
  userId      String   @unique
  role        String
  canTrials   Boolean  @default(false)
  canQuests   Boolean  @default(false)
  canUsers    Boolean  @default(false)
  canPayouts  Boolean  @default(false)
  canReports  Boolean  @default(false)
  canArena    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Achievement Engine ────────────────────────────────────────────────────

model Achievement {
  id          String          @id @default(cuid())
  name        String          @unique
  description String
  type        AchievementType @default(PERMANENT)
  icon        String          @default("🏆")
  condition   String
  xpBonus     Int             @default(0)
  isActive    Boolean         @default(true)
  createdById String?
  expiresAt   DateTime?
  createdAt   DateTime        @default(now())
  awardedTo   UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  achievementId String
  awardedById   String?
  awardedByAI   Boolean     @default(false)
  createdAt     DateTime    @default(now())
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  @@unique([userId, achievementId])
}

// ─── Titles Engine ─────────────────────────────────────────────────────────

model Title {
  id          String    @id @default(cuid())
  name        String    @unique
  description String
  condition   String
  icon        String    @default("⚔️")
  canExpire   Boolean   @default(false)
  isActive    Boolean   @default(true)
  createdById String?
  createdAt   DateTime  @default(now())
  awardedTo   UserTitle[]
}

model UserTitle {
  id          String    @id @default(cuid())
  userId      String
  titleId     String
  active      Boolean   @default(false)
  awardedById String?
  awardedByAI Boolean   @default(false)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       Title     @relation(fields: [titleId], references: [id], onDelete: Cascade)
  @@unique([userId, titleId])
}

// ─── Trust Engine ──────────────────────────────────────────────────────────

model TrustEvent {
  id        String   @id @default(cuid())
  userId    String
  action    String
  delta     Int
  reason    String
  source    String   @default("SYSTEM")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Community Posts ───────────────────────────────────────────────────────

model CommunityPost {
  id          String         @id @default(cuid())
  authorId    String
  content     String
  title       String?
  isAnonymous Boolean        @default(false)
  isPinned    Boolean        @default(false)
  visibility  PostVisibility @default(MEMBERS_ONLY)
  flagged     Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  author      User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

// ─── Feedback System ───────────────────────────────────────────────────────

model Feedback {
  id        String          @id @default(cuid())
  userId    String?
  email     String?
  type      String          @default("GENERAL")
  content   String
  status    String          @default("OPEN")
  isRead    Boolean         @default(false)
  createdAt DateTime        @default(now())
  user      User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  replies   FeedbackReply[]
}

model FeedbackReply {
  id         String   @id @default(cuid())
  feedbackId String
  authorId   String
  content    String
  createdAt  DateTime @default(now())
  feedback   Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  author     User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

// ─── Feature Unlock ────────────────────────────────────────────────────────

model UserFeatureUnlock {
  id           String   @id @default(cuid())
  userId       String
  feature      String
  unlockedById String
  note         String?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, feature])
}

// ─── Profile Verification ──────────────────────────────────────────────────

model ProfileVerification {
  id          String   @id @default(cuid())
  userId      String
  type        String
  status      String   @default("PENDING")
  evidence    String?
  reviewedBy  String?
  submittedAt DateTime @default(now())
  reviewedAt  DateTime?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}